# Local app mode. New users can run the app with these defaults.
APP_MODE=mock
DATA_PROVIDER=mock
HOST=127.0.0.1
PORT=4310

# Optional: load another env file at startup.
# In Docker, setup mode can also load this interactively from /setup.
ENV_FILE=

# OCI live mode. Required only when DATA_PROVIDER=oci.
# Keep real values in .env only. Do not commit .env.
OCI_TENANCY_OCID=ocid1.tenancy.oc1..example
OCI_USER_OCID=ocid1.user.oc1..example
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff
OCI_REGION=ap-mumbai-1

# For Docker, this must be the path inside the container.
# Mount ./.oci to /oci and keep the private key at ./.oci/oci_api_key.pem.
OCI_KEY_FILE=/oci/oci_api_key.pem
OCI_PROFILE=DEFAULT
OCI_CONFIG_FILE=.oci/config
OCI_CLI_PATH=.venv/bin/oci

# OpenAI recommendation mode. Required only when LLM_PROVIDER=openai.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
