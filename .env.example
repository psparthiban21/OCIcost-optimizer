# Local app mode
APP_MODE=mock
DATA_PROVIDER=mock
HOST=127.0.0.1
PORT=4310

# OCI integration mode, for a later real-data provider.
# Keep real values in .env only. Do not commit .env.
OCI_TENANCY_OCID=ocid1.tenancy.oc1..example
OCI_USER_OCID=ocid1.user.oc1..example
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff
OCI_REGION=ap-mumbai-1
OCI_KEY_FILE=/oci/oci_api_key.pem
OCI_PROFILE=DEFAULT
OCI_CONFIG_FILE=.oci/config
OCI_CLI_PATH=.venv/bin/oci

# OpenAI recommendation mode, for a later LLM provider.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
